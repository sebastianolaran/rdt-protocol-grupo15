#!/usr/bin/env python3
import argparse
import os
import socket
import sys
import time

from lib.protocol import CONSTANTS, ERROR_CODES, Packet
from lib.selective_repeat import SRReceiver
from lib.stop_and_wait import SAWReceiver


def main():
    parser = argparse.ArgumentParser(
        description="TP1: Download de archivo desde el servidor"
    )
    grupo = parser.add_mutually_exclusive_group()
    grupo.add_argument('-v', '--verbose', action='store_true',
                       help='Aumentar verbosidad')
    grupo.add_argument('-q', '--quiet', action='store_true',
                       help='Disminuir verbosidad')
    parser.add_argument('-H', '--host', type=str, default='127.0.0.1',
                        help='Dirección IP del servidor')
    parser.add_argument('-p', '--port', type=int, required=True,
                        help='Puerto del servidor')
    parser.add_argument('-d', '--dst', type=str, required=True,
                        help='Ruta donde se descarga el archivo')
    parser.add_argument('-n', '--name', type=str, required=True,
                        help='Nombre del archivo en el servidor')
    parser.add_argument('-r', '--protocol', default='StopAndWait',
                        choices=['StopAndWait', 'SelectiveRepeat'],
                        help='Protocolo de recuperación de errores')
    args = parser.parse_args()

    FLAG_I = CONSTANTS["FLAG_I"]
    STOP_AND_WAIT = CONSTANTS["STOP_AND_WAIT"]
    SELECTIVE_REPEAT = CONSTANTS["SR_WINDOW_SIZE"]
    MAX_RETRIES = CONSTANTS["MAX_RETRIES"]
    DEFAULT_TIMEOUT = CONSTANTS["DEFAULT_TIMEOUT"]
    MAX_PKT_SIZE = CONSTANTS["MAX_PKT_SIZE"]

    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    server_addr = (args.host, args.port)

    if args.protocol == 'SelectiveRepeat':
        init_pkt = Packet.build(
            0, 0, FLAG_I, SELECTIVE_REPEAT,
            f"download|{args.name}".encode()
        )
    else:
        init_pkt = Packet.build(
            0, 0, FLAG_I, STOP_AND_WAIT,
            f"download|{args.name}".encode()
        )
    connected = False
    for attempt in range(MAX_RETRIES):
        try:
            sock.sendto(init_pkt, server_addr)
            start_time = time.time()
            
            while time.time() - start_time < DEFAULT_TIMEOUT:
                remaining_timeout = DEFAULT_TIMEOUT - (time.time() - start_time)
                if remaining_timeout <= 0:
                    break
                sock.settimeout(remaining_timeout)
                
                try:
                    raw, _ = sock.recvfrom(MAX_PKT_SIZE)
                    resp = Packet.parse(raw)
                    if resp.flags & FLAG_I:
                        error = resp.flags & 0x0F
                        if error == ERROR_CODES["OK"]:
                            connected = True
                            break
                        elif error == ERROR_CODES["FILE_NOT_FOUND"]:
                            print("Error: archivo no encontrado en el servidor.",
                                  file=sys.stderr)
                            sock.close()
                            sys.exit(1)
                        elif error == ERROR_CODES["PROTO_MISMATCH"]:
                            print("Error: protocolo no soportado por el servidor.",
                                  file=sys.stderr)
                            sock.close()
                            sys.exit(1)
                        elif error == ERROR_CODES["PERMISSION_DENIED"]:
                            print("Error: sin permisos para acceder al archivo.",
                                  file=sys.stderr)
                            sock.close()
                            sys.exit(1)
                        else:
                            print(f"Error del servidor: código {error}",
                                  file=sys.stderr)
                            sock.close()
                            sys.exit(1)
                except (ValueError, OSError):
                    # Ignorar paquetes de data o basura, intentar de nuevo
                    continue
            if connected:
                break
        except (TimeoutError, OSError):
            pass
            
        if not connected and args.verbose:
            print(f"Reintento INIT {attempt + 1}/{MAX_RETRIES}...")

    if not connected:
        print("Error: servidor no responde.", file=sys.stderr)
        sock.close()
        sys.exit(1)

    if args.verbose:
        print(f"Conectado. Descargando '{args.name}' a '{args.dst}'...")

    t0 = time.time()
    try:
        if args.protocol == 'SelectiveRepeat':
            receiver = SRReceiver(sock, server_addr, verbose=args.verbose)
        else:
            receiver = SAWReceiver(sock, server_addr, verbose=args.verbose)
        receiver.receive_file(args.dst)
    except (TimeoutError, OSError) as e:
        print(f"Error de transferencia: {e}", file=sys.stderr)
        sock.close()
        sys.exit(1)

    elapsed = time.time() - t0
    if not args.quiet:
        size = os.path.getsize(args.dst)
        print(f"Descarga completada en {elapsed:.2f}s ({size / elapsed / 1024:.1f} KB/s)")
    sock.close()


if __name__ == "__main__":
    main()
