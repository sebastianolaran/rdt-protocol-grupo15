#!/usr/bin/env python3
import argparse
import os
import socket
import sys
import threading
import queue

from lib.protocol import CONSTANTS, ERROR_CODES, Packet
from lib.stop_and_wait import SAWReceiver, SAWSender

# client_addr -> cola de datagramas entrantes de esa sesión
sessions = {}
sessions_lock = threading.Lock()


def handle_session(addr, session_queue, server_socket, storage, verbose):
    FLAG_I = CONSTANTS["FLAG_I"]
    STOP_AND_WAIT = CONSTANTS["STOP_AND_WAIT"]
    DEFAULT_TIMEOUT = CONSTANTS["DEFAULT_TIMEOUT"]

    def send_error(code):
        err_pkt = Packet.build(0, 0, FLAG_I, code, b"")
        server_socket.sendto(err_pkt, addr)

    if verbose:
        print(f"[+] Nueva sesión: {addr}")

    try:
        raw = session_queue.get(timeout=DEFAULT_TIMEOUT)
        pkt = Packet.parse(raw)

        if not (pkt.flags & FLAG_I):
            send_error(ERROR_CODES["BAD_PACKET"])
            return

        try:
            op, filename = pkt.data.decode().split("|", 1)
        except (UnicodeDecodeError, ValueError):
            send_error(ERROR_CODES["BAD_PACKET"])
            return

        if pkt.win != STOP_AND_WAIT:
            send_error(ERROR_CODES["PROTO_MISMATCH"])
            return

        resp = Packet.build(0, 1, FLAG_I, STOP_AND_WAIT, b"")
        server_socket.sendto(resp, addr)

        if op == "upload":
            receiver = SAWReceiver(server_socket, addr, verbose,
                                   recv_queue=session_queue)
            data = receiver.receive_bytes()
            dest = os.path.join(storage, filename)
            with open(dest, "wb") as f:
                f.write(data)
            if verbose:
                print(f"[{addr}] upload completado: {dest}")

        elif op == "download":
            filepath = os.path.join(storage, filename)
            if not os.path.exists(filepath):
                send_error(ERROR_CODES["FILE_NOT_FOUND"])
                return
            sender = SAWSender(server_socket, addr, verbose,
                               recv_queue=session_queue)
            sender.send_file(filepath)
            sender.close()
            if verbose:
                print(f"[{addr}] download completado: {filepath}")

        else:
            send_error(ERROR_CODES["BAD_PACKET"])

    except Exception as e:
        if verbose:
            print(f"[{addr}] error en sesión: {e}")

    finally:
        with sessions_lock:
            sessions.pop(addr, None)
        if verbose:
            print(f"[-] Sesión cerrada: {addr}")


def start_server(host, port, storage, verbose):
    server_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    server_socket.bind((host, port))
    print(f"Escuchando en {host}:{port}  (storage: {storage})")

    while True:
        data, addr = server_socket.recvfrom(65535)

        with sessions_lock:
            if addr not in sessions:
                # Primer datagrama de este cliente: abrir una sesión nueva
                q = queue.Queue()
                sessions[addr] = q
                t = threading.Thread(
                    target=handle_session,
                    args=(addr, q, server_socket, storage, verbose),
                    daemon=True,
                )
                t.start()

            sessions[addr].put(data)


def main():
    parser = argparse.ArgumentParser(
        description="TP1: Aplicación de arranque del servidor de carga-descarga"
    )

    grupoExcluyente = parser.add_mutually_exclusive_group()
    grupoExcluyente.add_argument('-v', '--verbose', action='store_true', help='Aumentar verbosidad')
    grupoExcluyente.add_argument('-q', '--quiet', action='store_true', help='Disminuir verbosidad')

    parser.add_argument('-H', '--host', type=str, default='127.0.0.1', help='Dirección IP del servidor')
    parser.add_argument('-p', '--port', type=int, required=True, help='Puerto del servidor')
    parser.add_argument('-s', '--storage', type=str, required=True, help='Ruta donde iniciar el servidor')

    args = parser.parse_args()

    try:
        start_server(args.host, args.port, args.storage, args.verbose)
    except KeyboardInterrupt:
        print("\nServidor finalizado por el usuario.")
        sys.exit(0)

if __name__ == "__main__":
    main()